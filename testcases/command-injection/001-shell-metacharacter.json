{
  "vector": "command-injection",
  "id": "command-injection/001-shell-metacharacter",
  "severity": "high",
  "description": "An argument carries shell metacharacters intended to break out of a server-side command.",
  "fixture": {
    "type": "tool-call",
    "tool": {
      "name": "ping_host",
      "description": "Ping a host.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          }
        },
